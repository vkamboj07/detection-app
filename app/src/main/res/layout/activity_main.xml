<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,VisualLintButtonSize,VisualLintSystemWindow"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Footfall Tracker"
            android:textSize="26sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- Top Buttons Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnStartTracker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#B3C4C1"
                android:textColor="#1E1E1E"
                android:text="Start Tracker"
                app:cornerRadius="24dp"/>

            <Button
                android:id="@+id/btnLiveDevices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="#2D3A38"
                android:textColor="#B3C4C1"
                android:text="Live View"
                app:cornerRadius="24dp"/>

            <Button
                android:id="@+id/btnExportData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="#555555"
                app:strokeWidth="1dp"
                android:textColor="#B0B0B0"
                android:text="Export Data"
                app:cornerRadius="24dp"/>

            <Button
                android:id="@+id/btnDebugLog"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@android:color/transparent"
                android:textColor="#B0B0B0"
                android:text="Debug Log"
                app:cornerRadius="24dp"/>

            <Button
                android:id="@+id/btnSyncData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_columnSpan="2"
                android:layout_marginTop="16dp"
                android:backgroundTint="#FF9800"
                android:textColor="#1E1E1E"
                android:text="Sync Cloud Data"
                app:cornerRadius="24dp"/>

        </GridLayout>

        <!-- Dashboard Overview Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard Overview"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Stats Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="8dp">

            <!-- Card 1: Current -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="16dp"
                app:contentPadding="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp">
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Current" android:textColor="#B0B0B0" android:textSize="14sp" />
                    <TextView android:id="@+id/tvCurrentDevices" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="32sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Today -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="16dp"
                app:contentPadding="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp">
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today" android:textColor="#B0B0B0" android:textSize="14sp" />
                    <TextView android:id="@+id/tvTotalVisitors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="32sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Returning -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="16dp"
                app:contentPadding="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp">
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Returning" android:textColor="#B0B0B0" android:textSize="14sp" />
                    <TextView android:id="@+id/tvReturningVisitors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="32sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Avg Dwell -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#222222"
                app:cardCornerRadius="16dp"
                app:contentPadding="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#333333"
                app:strokeWidth="1dp">
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg Dwell" android:textColor="#B0B0B0" android:textSize="14sp" />
                    <TextView android:id="@+id/tvAvgDwellTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0m" android:textColor="#FFFFFF" android:textSize="32sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- Peak Activity Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#344845"
            app:cardCornerRadius="16dp"
            app:contentPadding="24dp"
            android:layout_marginBottom="24dp"
            app:cardElevation="0dp">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Peak Activity (Mins Ago)" android:textColor="#D0D0D0" android:textSize="14sp" />
                <TextView android:id="@+id/tvPeakHour" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- mins ago" android:textColor="#FFFFFF" android:textSize="32sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Active Devices Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">
            
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hourly Traffic Trend"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/hourlyTrafficChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Line Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">
            
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Devices (Last 5 Mins)"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/activeDevicesLineChart"
                    android:layout_width="match_parent"
                    android:layout_height="150dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Category Breakdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">
            
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category Breakdown"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/categoryPieChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Protocol Breakdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">
            
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protocol Breakdown"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/sourcePieChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
