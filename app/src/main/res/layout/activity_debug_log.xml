<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    tools:ignore="HardcodedText,VisualLintSystemWindow">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back"
            android:layout_marginEnd="16dp"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug: Session Log"
            android:textSize="26sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/btnLoadJson"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:backgroundTint="#B3C4C1"
        android:textColor="#1E1E1E"
        android:text="Load Session History JSON"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnClearDb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:backgroundTint="#CF6679"
        android:textColor="#000000"
        android:text="Clear Database"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#222222"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvJsonOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#03DAC6"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="Waiting for output..." />
    </ScrollView>

</LinearLayout>
